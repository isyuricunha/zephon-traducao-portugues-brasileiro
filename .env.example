# Mistral AI configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_AGENT_ID=your_mistral_agent_id_here

# Optional tuning parameters
# Number of entries to send per API call (default: 20)
BATCH_SIZE=20

# Maximum retries on API error (default: 3)
MAX_RETRIES=3

# Seconds to wait between API batches to avoid rate limiting (default: 3.0)
BATCH_DELAY=3.0
